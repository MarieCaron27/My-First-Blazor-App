@page "/counter"
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="IncrementCount">Click me</button>

<div class="mt-3">
    <input @bind="text"  @bind:event="oninput" @bind:after="Search"/> <!-- Allows to change the input value when the text value does -->
    <button @onclick="OnClick">Clear</button>
    <p>@text</p>
    <p>@searchResult</p>
</div>


@code 
{
    private int currentCount = 0;

    private string text = ""; //Value of the input

    private string searchResult = "";

    private void IncrementCount() => currentCount++;

    private void OnClick(MouseEventArgs args) => text = "";

    private async Task Search()
    {
        searchResult = "Searching...";
        await Task.Delay(2000);
        searchResult = $"Found {Random.Shared.Next()} results !";
    }
}



