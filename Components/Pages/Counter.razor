    <MyButton OnClick="IncrementCount" class="btn btn-success">Button Click !</MyButton>

<div class="mt-3">
    <input  @oninput="OnChange"/>
    <p>@text</p>
</div>

<div style="background-color:lightblue" @onmouseover="MouseOn" @onmouseout="MouseOut">
    @divText
</div> <!-- Changes the text of the div when the mouse is on and out of it -->

@code {
    private int currentCount = 0;

    private string text = ""; //Value of the input

    private string divText = "Mouse out";

    private void IncrementCount() => currentCount++;

    private void OnChange(ChangeEventArgs args)
    {
        text = (string)args.Value!; //Here we change the text value with the value typed by the user in the input

        //We cast the args as a string because it is an object
        //The ! is here to notify that the value can be null
        //The difference between @oninput and @onchange : OnInput updates the value of the text as the user is typing it in the input frame
        //OnChange methods updates the value of the text after the user has typed and click outside the input frame.
    }

    private void MouseOn(MouseEventArgs args) => divText = "Mouse On";

    private void MouseOut(MouseEventArgs args) => divText = "Mouse Out";
}

}
